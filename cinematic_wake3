def _enum_windows_titles() -> list[tuple[str, str]]:
    results = []
    EnumWindowsProc = ctypes.WINFUNCTYPE(ctypes.c_bool, wintypes.HWND, ctypes.c_long)

    def _callback(hwnd, _):
        try:
            if not user32.IsWindowVisible(hwnd):
                return True
            length = user32.GetWindowTextLengthW(hwnd)
            if length == 0:
                return True
            buf = ctypes.create_unicode_buffer(length + 1)
            user32.GetWindowTextW(hwnd, buf, length + 1)
            title = buf.value.strip().lower()
            if not title:
                return True
            pid = wintypes.DWORD()
            user32.GetWindowThreadProcessId(hwnd, ctypes.byref(pid))
            PROCESS_QUERY_LIMITED = 0x1000
            h = kernel32.OpenProcess(PROCESS_QUERY_LIMITED, False, pid.value)
            if h:
                buf2 = ctypes.create_unicode_buffer(260)
                size = wintypes.DWORD(260)
                kernel32.QueryFullProcessImageNameW(h, 0, buf2, ctypes.byref(size))
                kernel32.CloseHandle(h)
                proc_name = Path(buf2.value).stem.lower()
                if proc_name in _MEDIA_PROCESS_NAMES:
                    results.append((proc_name, title))
        except Exception:
            pass
        return True

    user32.EnumWindows(EnumWindowsProc(_callback), 0)
    return results


def _check_window_titles() -> bool:
    try:
        windows = _enum_windows_titles()
        for proc_name, title in windows:
            for kw in _MEDIA_TITLE_KEYWORDS:
                if kw in title:
                    return True
    except Exception:
        pass
    return False


def _check_powercfg() -> bool:
    try:
        output = subprocess.check_output(
            ["powercfg", "/requests"],
            creationflags=subprocess.CREATE_NO_WINDOW,
            text=True, encoding='utf-8', errors='ignore',
            timeout=5
        )
        output_lower = output.lower()

        target_apps = [
            "vlc.exe", "mpc-hc", "mpc-be", "spotify.exe",
            "wmplayer.exe", "groove.exe", "movies.exe",
            "potplayer", "foobar2000", "winamp.exe",
        ]
        for app in target_apps:
            if app in output_lower:
                return True

        in_lock_section = False
        for line in output_lower.splitlines():
            line = line.strip()
            if any(line.startswith(h) for h in
                   ("display:", "system:", "anzeige:", "affichage:",
                    "système:", "sistema:", "bildschirm:")):
                in_lock_section = True
                continue
            if in_lock_section:
                if line == "" or (line.endswith(":") and len(line) < 30):
                    in_lock_section = False
                    continue
                if "[" in line:
                    return True
    except Exception:
        pass
    return False


