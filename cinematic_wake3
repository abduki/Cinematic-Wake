def card_frame(parent, **kw):
    return tk.Frame(parent, bg=C_CARD, **kw)


def label(parent, text, font=None, fg=None, **kw):
    return tk.Label(parent, text=text, font=font or FONT_SMALL,
                    fg=fg or C_FG, bg=parent.cget("bg"), **kw)


def sep(parent):
    tk.Frame(parent, bg=C_BORDER, height=1).pack(fill="x", pady=8)


class CWSlider:
    def __init__(self, parent, title, subtitle, variable,
                 from_, to_, resolution=1, fmt=None, command=None):
        self.var     = variable
        self.fmt     = fmt
        self.command = command
        outer = card_frame(parent, padx=16, pady=12)
        outer.pack(fill="x", pady=5)
        top = tk.Frame(outer, bg=C_CARD)
        top.pack(fill="x")
        label(top, title, font=FONT_LABEL, fg=C_FG).pack(side="left")
        self._vl = tk.Label(top, font=FONT_LABEL, fg=C_ACCENT, bg=C_CARD)
        self._vl.pack(side="right")
        label(outer, subtitle, font=FONT_SMALL, fg=C_FG2).pack(anchor="w", pady=(2, 4))
        tk.Scale(outer, variable=variable, from_=from_, to=to_,
                 orient="horizontal", resolution=resolution,
                 bg=C_CARD, fg=C_FG, troughcolor=C_BG,
                 activebackground=C_ACCENT, highlightthickness=0,
                 sliderlength=18, showvalue=False,
                 command=self._on_change).pack(fill="x")
        self._refresh_label()

    def _refresh_label(self):
        v = self.var.get()
        self._vl.config(text=(self.fmt(v) if self.fmt else str(v)))

    def _on_change(self, _):
        self._refresh_label()
        if self.command:
            self.command()


class CWToggle:
    def __init__(self, parent, variable: tk.BooleanVar, command=None):
        self.var     = variable
        self.command = command
        self.canvas  = tk.Canvas(parent, width=44, height=24,
                                 bg=parent.cget("bg"), highlightthickness=0,
                                 cursor="hand2")
        self.canvas.bind("<Button-1>", self._toggle)
        self._draw()

    def pack(self, **kw):
        self.canvas.pack(**kw)

    def _toggle(self, _=None):
        self.var.set(not self.var.get())
        self._draw()
        if self.command:
            self.command()

    def redraw(self):
        self._draw()

    def _draw(self):
        self.canvas.delete("all")
        on = self.var.get()
        self._rr(2, 4, 42, 20, 8, fill=C_ACCENT if on else C_BORDER)
        x = 30 if on else 14
        self.canvas.create_oval(x - 8, 4, x + 8, 20, fill=C_FG, outline="")

    def _rr(self, x1, y1, x2, y2, r, **kw):
        for (sa, ex) in [(90, 90), (0, 90), (180, 90), (270, 90)]:
            ax = x1 if sa in (90, 180) else x2 - 2 * r
            ay = y1 if sa in (0, 90)  else y2 - 2 * r
            self.canvas.create_arc(ax, ay, ax + 2 * r, ay + 2 * r,
                                   start=sa, extent=ex, style="pieslice",
                                   outline="", **kw)
        self.canvas.create_rectangle(x1 + r, y1, x2 - r, y2, outline="", **kw)
        self.canvas.create_rectangle(x1, y1 + r, x2, y2 - r, outline="", **kw)


def toggle_row(parent, text, subtitle, var, cmd=None):
    row  = tk.Frame(parent, bg=C_CARD)
    row.pack(fill="x", padx=16, pady=6)
    left = tk.Frame(row, bg=C_CARD)
    left.pack(side="left", fill="x", expand=True)
    label(left, text,     font=FONT_LABEL, fg=C_FG).pack(anchor="w")
    label(left, subtitle, font=FONT_SMALL, fg=C_FG2).pack(anchor="w")
    tog = CWToggle(row, var, command=cmd)
    tog.pack(side="right", padx=(8, 0))
    return tog


