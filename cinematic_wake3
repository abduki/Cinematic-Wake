def _gen_tone(freq: int, duration_ms: int, volume=0.3, fade_ms=80) -> bytes:
    rate   = 44100
    n      = int(rate * duration_ms / 1000)
    if n == 0:
        return b""
    fade_n = min(int(rate * fade_ms / 1000), n // 2)
    out = []
    for i in range(n):
        if fade_n > 0 and i < fade_n:
            env = i / fade_n
        elif fade_n > 0 and i >= n - fade_n:
            env = (n - i) / fade_n
        else:
            env = 1.0
        s = int(32767 * volume * env * math.sin(2 * math.pi * freq * i / rate))
        out.append(struct.pack("<h", max(-32767, min(32767, s))))
    return b"".join(out)


def play_tone(freq: int, duration_ms: int):
    def _play():
        try:
            tmp = Path(os.environ.get("TEMP", ".")) / "_cw_tone.wav"
            with wave.open(str(tmp), "wb") as wf:
                wf.setnchannels(1)
                wf.setsampwidth(2)
                wf.setframerate(44100)
                wf.writeframes(_gen_tone(freq, duration_ms))
            winsound.PlaySound(str(tmp), winsound.SND_FILENAME | winsound.SND_NODEFAULT)
        except Exception:
            pass
    threading.Thread(target=_play, daemon=True).start()


def ease(t: float, curve: str) -> float:
    t = max(0.0, min(1.0, t))
    if curve == "linear":      return t
    if curve == "ease_in":     return t * t
    if curve == "ease_out":    return 1 - (1 - t) ** 2
    if curve == "ease_in_out": return t * t * (3 - 2 * t)
    if curve == "sine":        return (1 - math.cos(t * math.pi)) / 2
    return t


def get_monitor_rects() -> list:
    rects = []
    MonitorEnumProc = ctypes.WINFUNCTYPE(
        ctypes.c_bool, ctypes.c_ulong, ctypes.c_ulong,
        ctypes.POINTER(wintypes.RECT), ctypes.c_double)

    def _cb(hMon, hdcMon, lprc, dw):
        r = lprc.contents
        rects.append((r.left, r.top, r.right - r.left, r.bottom - r.top))
        return True

    user32.EnumDisplayMonitors(None, None, MonitorEnumProc(_cb), 0)
    if not rects:
        rects = [(user32.GetSystemMetrics(76), user32.GetSystemMetrics(77),
                  user32.GetSystemMetrics(78), user32.GetSystemMetrics(79))]
    return rects


