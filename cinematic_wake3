                 fg=C_FG2, bg=C_PANEL).pack(side="left", padx=6, pady=28)
        self._status_lbl = tk.Label(hdr, text="", font=FONT_SMALL,
                                    fg=C_FG2, bg=C_PANEL)
        self._status_lbl.pack(side="right", padx=20)
        self._pause_btn = tk.Button(hdr, text="⏸  PAUSE",
                                    font=FONT_SMALL, bg=C_CARD, fg=C_FG2,
                                    relief="flat", padx=10, pady=4, cursor="hand2",
