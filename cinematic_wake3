    def _scrollable(self, parent) -> tk.Frame:
        canvas = tk.Canvas(parent, bg=C_PANEL, highlightthickness=0)
        sb     = tk.Scrollbar(parent, orient="vertical", command=canvas.yview)
        inner  = tk.Frame(canvas, bg=C_PANEL)
        inner.bind("<Configure>",
                   lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
        canvas.create_window((0, 0), window=inner, anchor="nw")
        canvas.configure(yscrollcommand=sb.set)
        canvas.pack(side="left", fill="both", expand=True)
        sb.pack(side="right", fill="y")

        def _on_enter(e):
            canvas.bind_all("<MouseWheel>",
                            lambda ev: canvas.yview_scroll(-1 * (ev.delta // 120), "units"))

        def _on_leave(e):
            canvas.unbind_all("<MouseWheel>")

        canvas.bind("<Enter>", _on_enter)
        canvas.bind("<Leave>", _on_leave)
        inner.bind("<Enter>", _on_enter)
        inner.bind("<Leave>", _on_leave)
        return inner

    def _stat_col(self, parent, title, value):
        col = tk.Frame(parent, bg=C_PANEL)
        col.pack(side="left", padx=16)
        label(col, title, font=FONT_SMALL, fg=C_FG2).pack()
        v = tk.Label(col, text=value, font=("Consolas", 14, "bold"), fg=C_ACCENT, bg=C_PANEL)
        v.pack()
        return v

    def _on_theme_change(self):
        t = self._theme_var.get()
        if t in THEME_COLORS:
            self._color_var.set(THEME_COLORS[t])
            self._swatch.config(bg=THEME_COLORS[t])
            self._color_lbl.config(text=THEME_COLORS[t])
        elif t == "custom":
            self._pick_color()
        self._save()

    def _pick_color(self, _=None):
        c = colorchooser.askcolor(color=self._color_var.get(), title="Choose overlay colour")
        if c and c[1]:
            self._color_var.set(c[1])
            self._swatch.config(bg=c[1])
            self._color_lbl.config(text=c[1])
            self._theme_var.set("custom")
            self._save()

    def _save(self, *_):
        def _g(attr, default=None):
            try:
                return getattr(self, attr).get()
            except AttributeError:
                return default

        self.cfg["idle_minutes"] = _g("_idle_var", self.cfg.get("idle_minutes", 5))

        mv = _g("_media_var")
        if mv is not None:
            self.cfg["prevent_sleep_media"] = mv

        fo = _g("_fo_var")
        fi = _g("_fi_var")
        wd = _g("_wd_var")
        cv = _g("_curve_var")
        sc = _g("_countdown_var")
        cd = _g("_cd_sec_var")

        self.cfg["fade_out_ms"]  = fo * 100        if fo is not None else self.cfg.get("fade_out_ms",  1500)
        self.cfg["fade_in_ms"]   = fi * 100        if fi is not None else self.cfg.get("fade_in_ms",   1000)
        self.cfg["wake_delay_s"] = wd              if wd is not None else self.cfg.get("wake_delay_s", 3.0)
        self.cfg["fade_curve"]   = cv              if cv is not None else self.cfg.get("fade_curve",   "ease_in_out")

        if sc is not None: self.cfg["show_countdown"]    = sc
        if cd is not None: self.cfg["countdown_seconds"] = cd

        th = _g("_theme_var")
        co = _g("_color_var")
        if th is not None: self.cfg["overlay_theme"] = th
        if co is not None:
            self.cfg["overlay_color"] = co
            self.controller.overlay.set_color(co)

        am = _g("_ambient_var")
        mn = _g("_amb_min_var")
        sp = _g("_amb_spd_var")
        if am is not None: self.cfg["ambient_mode"]      = am
        if mn is not None: self.cfg["ambient_min_alpha"] = mn
        if sp is not None: self.cfg["ambient_speed_s"]   = sp

        asv = _g("_amb_sched_var")
        ass = _g("_amb_sched_start")
        ase = _g("_amb_sched_end")
        if asv is not None: self.cfg["ambient_schedule_enabled"] = asv
        if ass is not None: self.cfg["ambient_schedule_start"]   = ass
        if ase is not None: self.cfg["ambient_schedule_end"]     = ase

        aiv = _g("_amb_idle_var")
        aim = _g("_amb_idle_min")
        aem = _g("_amb_esc_min")
        aea = _g("_amb_esc_action")
        if aiv is not None: self.cfg["ambient_idle_enabled"]     = aiv
        if aim is not None: self.cfg["ambient_idle_minutes"]     = aim
        if aem is not None: self.cfg["ambient_escalate_minutes"] = aem
        if aea is not None: self.cfg["ambient_escalate_action"]  = aea

        se  = _g("_sched_var")
        ss  = _g("_sched_start")
        se2 = _g("_sched_end")
        if se  is not None: self.cfg["schedule_enabled"] = se
        if ss  is not None: self.cfg["schedule_start"]   = ss
        if se2 is not None: self.cfg["schedule_end"]     = se2

        sn = _g("_snd_var")
        sf = _g("_snd_sf_var")
        wf = _g("_snd_wf_var")
        sd = _g("_snd_dur_var")
        if sn is not None: self.cfg["sound_enabled"]     = sn
        if sf is not None: self.cfg["sound_sleep_freq"]  = sf
        if wf is not None: self.cfg["sound_wake_freq"]   = wf
        if sd is not None: self.cfg["sound_duration_ms"] = sd * 10

        ti = _g("_tray_start_var")
        if ti is not None:
            self.cfg["start_in_tray"] = ti

        save_config(self.cfg)
        self.controller.update_config(self.cfg)

    def _toggle_pause(self):
        self.controller._hotkey_pause()

    def _to_tray(self):
        self.root.withdraw()

    def _refresh(self):
        state  = self.controller.state
        colors = {
            State.IDLE:       (C_GREEN,  "ACTIVE"),
            State.COUNTDOWN:  (C_ORANGE, "COUNTDOWN"),
            State.FADING_OUT: (C_ORANGE, "FADING OUT"),
            State.AMBIENT:    (C_PURPLE, "AMBIENT"),
            State.CANCELING:  (C_PURPLE, "CANCELING"),
            State.SLEEPING:   (C_FG2,    "SLEEPING"),
            State.WAKING:     (C_ORANGE, "WAKING"),
            State.FADING_IN:  (C_ORANGE, "FADING IN"),
            State.PAUSED:     (C_RED,    "PAUSED"),
        }
        dot_col, txt = colors.get(state, (C_FG2, state.upper()))
        self._dot_canvas.itemconfig(self._dot_oval, fill=dot_col)

        if state == State.IDLE:
            if self.controller.cfg.get("prevent_sleep_media", True) and self.controller._media_is_playing:
                self._status_lbl.config(text="ACTIVE  •  Media Playing", fg=C_FG2)
            else:
                raw_idle = get_idle_seconds()
                if self.controller.cfg.get("prevent_sleep_media", True):
                    idle = min(raw_idle, time.time() - self.controller._last_media_active_time)
                else:
                    idle   = raw_idle
                remain = max(0, self.cfg["idle_minutes"] * 60 - idle)
                m, s   = divmod(int(remain), 60)
                self._status_lbl.config(text=f"{txt}  •  sleeps in {m:02d}:{s:02d}", fg=C_FG2)
        elif state == State.AMBIENT:
            elapsed = int(time.time() - self.controller._ambient_start)
            m, s    = divmod(elapsed, 60)
            self._status_lbl.config(text=f"AMBIENT  •  {m:02d}:{s:02d}", fg=C_PURPLE)
        else:
            self._status_lbl.config(text=txt, fg=dot_col)

        self._pause_btn.config(
            text="▶  RESUME" if state == State.PAUSED else "⏸  PAUSE",
            fg=C_ORANGE if state == State.PAUSED else C_FG2)

        self._update_stats()

        if self._tray:
            self._tray.update_tooltip(f"CinematicWake — {txt}")

    def _update_stats(self):
        stats = self.controller.stats
        self._stat_sleeps.config(text=str(stats.get("total_sleeps", 0)))
        secs    = int(stats.get("total_off_seconds", 0))
        h, rem  = divmod(secs, 3600)
        self._stat_time.config(text=f"{h}h {rem//60}m")
        last = stats.get("last_sleep")
        if last:
            try:
                dt = datetime.datetime.fromisoformat(last)
                self._stat_last.config(text=dt.strftime("%H:%M  %d %b"))
            except Exception:
                self._stat_last.config(text="—")

    def _diag_text(self) -> str:
        monitors      = get_monitor_rects()
        media_playing = self.controller._media_is_playing
        lines = [
            f"Python:    {sys.version.split()[0]}",
            f"Monitors:  {len(monitors)}  →  {monitors}",
            f"Idle now:  {get_idle_seconds():.1f} s",
            f"State:     {self.controller.state}",
            f"Media Lock:{media_playing}",
            f"Amb sched: {within_ambient_schedule(self.cfg)}",
            f"Sleep sched:{within_schedule(self.cfg)}",
            f"Autostart: {get_autostart()}",
        ]
        return "\n".join(lines)

    def _reset_stats(self):
        with self.controller._stats_lock:
            self.controller.stats = {"total_sleeps": 0, "total_off_seconds": 0, "last_sleep": None}
            save_stats(self.controller.stats)
        self._update_stats()

    def _animate_dot(self):
        state = self.controller.state
        if state in (State.FADING_OUT, State.FADING_IN, State.WAKING,
                     State.COUNTDOWN, State.CANCELING):
            col = C_ORANGE
        elif state == State.AMBIENT:
            t   = time.perf_counter() % 1.0
            col = C_PURPLE if t < 0.5 else "#8060B0"
        else:
            col = {State.IDLE: C_GREEN, State.SLEEPING: C_FG2,
                   State.PAUSED: C_RED}.get(state, C_FG2)
        self._dot_canvas.itemconfig(self._dot_oval, fill=col)
        self.root.after(500, self._animate_dot)
        self._refresh()


def main():
    if sys.platform != "win32":
        print("CinematicWake requires Windows.")
        sys.exit(1)

    cfg  = load_config()
    root = tk.Tk()

    overlay    = Overlay(root)
    controller = CinematicWake(overlay, cfg)
    ui         = SettingsUI(root, controller, cfg)

    overlay.set_color(cfg.get("overlay_color", "#000000"))

    tray   = SystemTray(root, controller, cfg, ui)
    ui._tray = tray

    controller.start()

    if cfg.get("start_in_tray", True):
        root.after(200, root.withdraw)

    root.mainloop()


if __name__ == "__main__":
    main()
