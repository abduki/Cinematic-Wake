        self._pause_btn.pack(side="right", padx=8, pady=18)

        tk.Frame(root, bg=C_BORDER, height=1).pack(fill="x")
        sbar = tk.Frame(root, bg=C_PANEL, pady=6)
        sbar.pack(fill="x")
        self._stat_sleeps = self._stat_col(sbar, "SLEEPS",     "0")
        tk.Frame(sbar, bg=C_BORDER, width=1).pack(side="left", fill="y", padx=12)
