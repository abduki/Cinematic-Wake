        self._stat_last   = self._stat_col(sbar, "LAST SLEEP", "—")
        tk.Button(sbar, text="SLEEP NOW", font=FONT_SMALL,
                  bg=C_ACCENT, fg=C_BG, relief="flat", padx=12, pady=3, cursor="hand2",
                  command=lambda: root.after(50, controller.force_sleep)
                  ).pack(side="right", padx=16)

        self._notebook = ttk.Notebook(root)
        self._notebook.pack(fill="both", expand=True)

        tabs = [
            ("tab_timing",   " ⏱  Timing  "),
            ("tab_appear",   " 🎨  Appear  "),
            ("tab_ambient",  " 🌙  Ambient "),
            ("tab_schedule", " 📅  Schedule"),
            ("tab_sound",    " 🔊  Sound  "),
            ("tab_hotkeys",  " ⌨  Hotkeys "),
            ("tab_system",   " ⚙  System  "),
        ]
        self._tab_frames = {}
        for attr, text in tabs:
            f = tk.Frame(self._notebook, bg=C_PANEL)
            self._notebook.add(f, text=text)
            self._tab_frames[attr] = f

        self._build_timing(   self._tab_frames["tab_timing"])
        self._build_appearance(self._tab_frames["tab_appear"])
        self._build_ambient(  self._tab_frames["tab_ambient"])
