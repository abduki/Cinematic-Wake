def set_autostart(enabled: bool):
    try:
        key = winreg.OpenKey(winreg.HKEY_CURRENT_USER, REG_RUN, 0, winreg.KEY_SET_VALUE)
        if enabled:
            winreg.SetValueEx(key, APP_NAME, 0, winreg.REG_SZ,
                              f'"{sys.executable}" "{os.path.abspath(__file__)}"')
        else:
            try:
                winreg.DeleteValue(key, APP_NAME)
            except FileNotFoundError:
                pass
        winreg.CloseKey(key)
    except Exception:
        pass


def get_autostart() -> bool:
    try:
        key = winreg.OpenKey(winreg.HKEY_CURRENT_USER, REG_RUN, 0, winreg.KEY_READ)
        winreg.QueryValueEx(key, APP_NAME)
        winreg.CloseKey(key)
        return True
    except Exception:
        return False


def _parse_time(s: str):
    h, m = map(int, s.split(":"))
    return datetime.time(h, m)


def _in_window(start_str: str, end_str: str) -> bool:
    now = datetime.datetime.now().time()
    try:
        start = _parse_time(start_str)
        end   = _parse_time(end_str)
        if start == end:
            return True
        if start < end:
            return start <= now <= end
        return now >= start or now <= end
    except Exception:
        return False


def within_schedule(cfg: dict) -> bool:
    if not cfg.get("schedule_enabled"):
        return True
    return _in_window(cfg["schedule_start"], cfg["schedule_end"])


def within_ambient_schedule(cfg: dict) -> bool:
    if not cfg.get("ambient_schedule_enabled"):
        return False
    return _in_window(cfg["ambient_schedule_start"], cfg["ambient_schedule_end"])


class Overlay:
    def __init__(self, root: tk.Tk):
        self.root             = root
        self._windows: list[tk.Toplevel] = []
        self._canvases: list[tk.Canvas]  = []
        self._alpha           = 0.0
        self._ambient_job     = None
        self._anim_job        = None
        self._last_monitor_rects: list = []
        self._build()
        self.root.after(10000, self._check_monitors)

    def _check_monitors(self):
        try:
            current = get_monitor_rects()
            if current != self._last_monitor_rects:
                saved_alpha = self._alpha
                self._build()
                if saved_alpha > 0:
                    self._set_alpha(saved_alpha)
                    for w in self._windows:
                        w.deiconify()
                        w.lift()
        except Exception:
            pass
        self.root.after(10000, self._check_monitors)

    def _build(self):
        for w in self._windows:
            try:
                w.destroy()
            except Exception:
                pass
        self._windows.clear()
        self._canvases.clear()
        rects = get_monitor_rects()
        self._last_monitor_rects = rects
        for (x, y, w, h) in rects:
            win = tk.Toplevel(self.root)
            win.overrideredirect(True)
            win.wm_attributes("-topmost", True)
            win.wm_attributes("-alpha",   0.0)
            win.geometry(f"{w}x{h}+{x}+{y}")
            canvas = tk.Canvas(win, width=w, height=h, bg="black", highlightthickness=0)
            canvas.pack(fill="both", expand=True)
            win.withdraw()
            self._windows.append(win)
            self._canvases.append(canvas)

    def set_color(self, hex_color: str):
        for c in self._canvases:
            c.configure(bg=hex_color)

    def show_countdown(self, seconds: int):
        self._clear_text()
        for c in self._canvases:
            w, h = c.winfo_width() or 1920, c.winfo_height() or 1080
            c.create_text(w // 2, h // 2, text=str(seconds),
                          font=("Helvetica", 96, "bold"),
                          fill="#1a1a1a", tags="countdown")

    def _clear_text(self):
        for c in self._canvases:
            c.delete("countdown")

    def _set_alpha(self, a: float):
        self._alpha = max(0.0, min(1.0, a))
        for w in self._windows:
            try:
                w.wm_attributes("-alpha", self._alpha)
            except Exception:
                pass

    def _cancel_anim(self):
        if self._anim_job:
            try:
                self.root.after_cancel(self._anim_job)
            except Exception:
                pass
            self._anim_job = None

    def _cancel_ambient(self):
        if self._ambient_job:
            try:
                self.root.after_cancel(self._ambient_job)
            except Exception:
                pass
            self._ambient_job = None

    def show_instant(self, alpha=1.0):
        self._cancel_anim()
        self._cancel_ambient()
        self._set_alpha(alpha)
        for w in self._windows:
            w.deiconify()
            w.lift()
        self.root.update()

    def hide_instant(self):
        self._cancel_anim()
        self._cancel_ambient()
        for w in self._windows:
            w.withdraw()
        self._alpha = 0.0

    def fade_to(self, target: float, duration_ms: int,
                curve: str = "ease_in_out", callback=None):
        self._cancel_anim()
        if duration_ms <= 0:
            if target > 0:
                self.show_instant(target)
            else:
                self.hide_instant()
            if callback:
                callback()
            return

        start_alpha = self._alpha
        delta       = target - start_alpha
        steps       = max(20, duration_ms // 16)
        interval    = max(1,  duration_ms // steps)
        t0          = time.perf_counter()

        if target > 0 and start_alpha == 0:
            for w in self._windows:
                w.deiconify()
                w.lift()

        def _step():
            t = min((time.perf_counter() - t0) * 1000 / duration_ms, 1.0)
            self._set_alpha(start_alpha + delta * ease(t, curve))
            if t < 1.0:
                self._anim_job = self.root.after(interval, _step)
            else:
                self._set_alpha(target)
                if target == 0:
                    for w in self._windows:
                        w.withdraw()
                if callback:
                    callback()
        _step()

    def start_ambient(self, min_alpha: float, cycle_s: float):
        self._cancel_ambient()
        t0 = time.perf_counter()

        def _pulse():
            t     = (time.perf_counter() - t0) % cycle_s / cycle_s
            alpha = min_alpha + (1.0 - min_alpha) * (0.5 - 0.5 * math.cos(2 * math.pi * t))
            self._set_alpha(alpha)
            self._ambient_job = self.root.after(33, _pulse)
        _pulse()

    def stop_ambient(self):
        self._cancel_ambient()

    def destroy(self):
        self._cancel_anim()
        self._cancel_ambient()
        for w in self._windows:
            try:
                w.destroy()
            except Exception:
                pass


class State:
    IDLE       = "idle"
    COUNTDOWN  = "countdown"
    FADING_OUT = "fading_out"
    AMBIENT    = "ambient"
    SLEEPING   = "sleeping"
    WAKING     = "waking"
    FADING_IN  = "fading_in"
    PAUSED     = "paused"
    CANCELING  = "canceling"


class CinematicWake:
    def __init__(self, overlay: Overlay, cfg: dict):
        self.overlay   = overlay
        self.cfg       = cfg
        self.state     = State.IDLE
        self.stats     = load_stats()
        self._lock     = threading.Lock()
        self._stats_lock = threading.Lock()

        self._sleep_start             = 0.0
        self._ambient_start           = 0.0
        self._idle_tick_at_sleep      = 0
        self._idle_tick_at_fade_start = 0
        self._countdown_val           = 0
        self._tray: "SystemTray | None" = None

        self._last_media_check_time  = 0.0
        self._media_is_playing       = False
        self._last_media_active_time = time.time()
        self._media_check_running    = False

        self._registered_hk_mods  = None
        self._registered_hk_sleep = None
        self._registered_hk_pause = None

    def start(self):
        keep_app_alive()
        threading.Thread(target=self._monitor_loop, daemon=True).start()
        threading.Thread(target=self._hotkey_loop,  daemon=True).start()

    def _monitor_loop(self):
        _keep_alive_counter = 0
        while True:
            time.sleep(0.5)
            with self._lock:
                state = self.state
                cfg   = dict(self.cfg)

            now           = time.time()
            prevent_media = cfg.get("prevent_sleep_media", True)

            _keep_alive_counter += 1
            if _keep_alive_counter >= 120:
                keep_app_alive()
                _keep_alive_counter = 0

            if prevent_media and state in (State.IDLE, State.AMBIENT, State.COUNTDOWN):
                if (not self._media_check_running
                        and now - self._last_media_check_time > 5.0):
                    self._media_check_running = True
                    def _do_check():
                        try:
                            result = is_media_playing()
                            self._media_is_playing = result
                            self._last_media_check_time = time.time()
                        finally:
                            self._media_check_running = False
                    threading.Thread(target=_do_check, daemon=True).start()
                if self._media_is_playing:
                    self._last_media_active_time = now

            if state == State.IDLE:
                if not within_schedule(cfg):
                    continue

                raw_idle = get_idle_seconds()
                if prevent_media:
                    idle_since_media = now - self._last_media_active_time
                    idle = min(raw_idle, idle_since_media)
                else:
                    idle = raw_idle

                thresh = cfg["idle_minutes"] * 60

                if within_ambient_schedule(cfg):
                    self._enter_ambient()
                    continue

                if cfg.get("ambient_idle_enabled"):
                    amb_thresh = cfg.get("ambient_idle_minutes", 2) * 60
                    if idle >= amb_thresh:
                        self._enter_ambient()
                        continue

                if cfg.get("show_countdown") and cfg.get("countdown_seconds", 0) > 0:
                    cd = cfg["countdown_seconds"]
                    if thresh - cd <= idle < thresh:
                        remaining = max(1, int(thresh - idle))
                        if remaining != self._countdown_val:
                            self._countdown_val = remaining
                            with self._lock:
                                if self.state == State.IDLE:
                                    self.state = State.COUNTDOWN
                            self.overlay.root.after(0, lambda r=remaining: self.overlay.show_countdown(r))
                            if self.overlay._alpha < 0.05:
                                self.overlay.root.after(0, lambda: self.overlay.show_instant(0.04))
                    elif idle < thresh - cd and self._countdown_val != 0:
                        self._countdown_val = 0
                        with self._lock:
                            if self.state == State.COUNTDOWN:
                                self.state = State.IDLE
                        self.overlay.root.after(0, self.overlay._clear_text)
                        if 0 < self.overlay._alpha < 0.1:
                            self.overlay.root.after(0, self.overlay.hide_instant)

                if idle >= thresh:
                    self._countdown_val = 0
                    self.overlay.root.after(0, self.overlay._clear_text)
                    if cfg.get("ambient_mode"):
                        self._enter_ambient()
                    else:
                        self._go_to_sleep()

            elif state == State.COUNTDOWN:
                if not within_schedule(cfg):
                    with self._lock:
                        if self.state == State.COUNTDOWN:
                            self.state = State.IDLE
                    self._countdown_val = 0
                    self.overlay.root.after(0, self.overlay._clear_text)
                    continue

                raw_idle = get_idle_seconds()
                if prevent_media:
                    idle = min(raw_idle, now - self._last_media_active_time)
                else:
                    idle = raw_idle
                thresh = cfg["idle_minutes"] * 60

                if idle >= thresh:
                    self._countdown_val = 0
                    self.overlay.root.after(0, self.overlay._clear_text)
                    if cfg.get("ambient_mode"):
                        self._enter_ambient()
                    else:
                        self._go_to_sleep()
                elif idle < thresh - cfg.get("countdown_seconds", 5):
                    with self._lock:
                        if self.state == State.COUNTDOWN:
                            self.state = State.IDLE
                    self._countdown_val = 0
                    self.overlay.root.after(0, self.overlay._clear_text)
                    if 0 < self.overlay._alpha < 0.1:
                        self.overlay.root.after(0, self.overlay.hide_instant)

            elif state == State.AMBIENT:
                if get_idle_tick() != self._idle_tick_at_sleep:
                    self._leave_ambient()
                    continue

                if prevent_media and self._media_is_playing:
                    self._leave_ambient()
                    continue

                raw_idle = get_idle_seconds()
                if prevent_media:
                    idle = min(raw_idle, now - self._last_media_active_time)
                else:
                    idle = raw_idle

                if cfg.get("ambient_schedule_enabled") and not within_ambient_schedule(cfg):
                    self._escalate_ambient(cfg)
                    continue

                if cfg.get("ambient_idle_enabled"):
                    elapsed_amb = time.time() - self._ambient_start
                    if elapsed_amb >= cfg.get("ambient_escalate_minutes", 10) * 60:
                        self._escalate_ambient(cfg)
                        continue

            elif state == State.SLEEPING:
                if get_idle_tick() != self._idle_tick_at_sleep:
                    self._begin_wake()

            elif state == State.FADING_OUT:
                if get_idle_tick() != self._idle_tick_at_fade_start:
                    self._cancel_sleep()

    def _hotkey_loop(self):
        msg = wintypes.MSG()
        while True:
            with self._lock:
                mods     = self.cfg.get("hotkey_mods",  0x0006)
                hk_sleep = self.cfg.get("hotkey_sleep", 0x4C)
                hk_pause = self.cfg.get("hotkey_pause", 0x50)

            if (mods     != self._registered_hk_mods  or
                hk_sleep != self._registered_hk_sleep or
                hk_pause != self._registered_hk_pause):
                if self._registered_hk_mods is not None:
                    user32.UnregisterHotKey(None, 1)
                    user32.UnregisterHotKey(None, 2)
                user32.RegisterHotKey(None, 1, mods | MOD_NOREPEAT, hk_sleep)
                user32.RegisterHotKey(None, 2, mods | MOD_NOREPEAT, hk_pause)
                self._registered_hk_mods  = mods
                self._registered_hk_sleep = hk_sleep
                self._registered_hk_pause = hk_pause

            if user32.PeekMessageW(ctypes.byref(msg), None, 0, 0, 1):
                if msg.message == WM_HOTKEY:
                    if msg.wParam == 1:
                        self.overlay.root.after(0, self._hotkey_sleep)
                    elif msg.wParam == 2:
                        self.overlay.root.after(0, self._hotkey_pause)
            time.sleep(0.05)

    def _hotkey_sleep(self):
        self.force_sleep()

    def _hotkey_pause(self):
        with self._lock:
            if self.state == State.PAUSED:
                self.state = State.IDLE
            elif self.state == State.IDLE:
                self.state = State.PAUSED
            else:
                return
        self.overlay.root.after(0, lambda: self.overlay.root.event_generate("<<PauseChanged>>", when="tail"))

    def _enter_ambient(self):
        with self._lock:
            if self.state not in (State.IDLE, State.COUNTDOWN, State.PAUSED):
                return
            self.state               = State.AMBIENT
            self._idle_tick_at_sleep = get_idle_tick()
            self._ambient_start      = time.time()
        cfg = dict(self.cfg)
        self.overlay.root.after(0, lambda: self._gui_enter_ambient(cfg))

    def _gui_enter_ambient(self, cfg: dict):
        self.overlay.set_color(cfg.get("overlay_color", "#000000"))
        self.overlay._clear_text()
        min_a = cfg.get("ambient_min_alpha", 0.85)
        dur   = cfg.get("fade_out_ms", 1500)
        curve = cfg.get("fade_curve", "ease_in_out")

        def _on_ready():
            with self._lock:
                if self.state != State.AMBIENT:
                    return
            self.overlay.start_ambient(min_a, cfg.get("ambient_speed_s", 8.0))
            self.overlay.root.event_generate("<<StateChanged>>", when="tail")

        self.overlay.fade_to(min_a, dur, curve, callback=_on_ready)
        self.overlay.root.event_generate("<<StateChanged>>", when="tail")

    def _leave_ambient(self):
        with self._lock:
            if self.state != State.AMBIENT:
                return
            self.state = State.CANCELING
        cfg = dict(self.cfg)
        self.overlay.root.after(0, lambda: self._gui_leave_ambient(cfg))

    def _gui_leave_ambient(self, cfg: dict):
        self.overlay.stop_ambient()
        dur   = cfg.get("fade_in_ms", 1000)
        curve = cfg.get("fade_curve", "ease_in_out")

        def _on_clear():
            with self._lock:
                self.state = State.IDLE
            self.overlay.root.event_generate("<<StateChanged>>", when="tail")

        self.overlay.fade_to(0.0, dur, curve, callback=_on_clear)
        self.overlay.root.event_generate("<<StateChanged>>", when="tail")

    def _escalate_ambient(self, cfg: dict):
        with self._lock:
            if self.state != State.AMBIENT:
                return
            self.state = State.IDLE
        action = cfg.get("ambient_escalate_action", "sleep")
        self.overlay.root.after(0, self.overlay.stop_ambient)
        if action == "sleep":
            self._go_to_sleep()
        else:
            self.overlay.root.after(0, lambda: self._gui_leave_ambient(cfg))

    def _go_to_sleep(self):
        with self._lock:
            if self.state not in (State.IDLE, State.COUNTDOWN, State.PAUSED):
                return
            self.state                    = State.FADING_OUT
            self._idle_tick_at_sleep      = get_idle_tick()
            self._idle_tick_at_fade_start = get_idle_tick()
            self._sleep_start             = time.time()
        cfg = dict(self.cfg)
        if cfg.get("sound_enabled"):
            play_tone(cfg["sound_sleep_freq"], cfg["sound_duration_ms"])
        self.overlay.root.after(0, lambda: self._gui_fade_to_sleep(cfg))

    def _cancel_sleep(self):
        with self._lock:
            if self.state != State.FADING_OUT:
                return
            self.state = State.CANCELING
        cfg = dict(self.cfg)
        self.overlay.root.after(0, lambda: self._gui_cancel_sleep(cfg))

    def _gui_cancel_sleep(self, cfg: dict):
        self.overlay._cancel_anim()
        self.overlay._clear_text()
        cur = self.overlay._alpha
        dur = max(200, int(cfg.get("fade_out_ms", 1500) * cur))

        def _done():
            with self._lock:
                self.state = State.IDLE
            self._countdown_val = 0
            self.overlay.root.event_generate("<<StateChanged>>", when="tail")

        if cur <= 0.0:
            self.overlay.hide_instant()
            _done()
        else:
            self.overlay.fade_to(0.0, dur, cfg.get("fade_curve", "ease_in_out"), _done)
        self.overlay.root.event_generate("<<StateChanged>>", when="tail")

    def _gui_fade_to_sleep(self, cfg: dict):
        with self._lock:
            if self.state != State.FADING_OUT:
                return
        self.overlay.set_color(cfg.get("overlay_color", "#000000"))
        self.overlay._clear_text()

        def _on_black():
            with self._lock:
                if self.state != State.FADING_OUT:
                    return
                self.state               = State.SLEEPING
                self._idle_tick_at_sleep = get_idle_tick()
            self.overlay.root.after(100, send_monitor_off)
            with self._stats_lock:
                self.stats["total_sleeps"] += 1
                self.stats["last_sleep"]    = datetime.datetime.now().isoformat()
                save_stats(self.stats)
            self.overlay.root.event_generate("<<StateChanged>>", when="tail")

        self.overlay.fade_to(1.0, cfg.get("fade_out_ms", 1500),
                              cfg.get("fade_curve", "ease_in_out"), _on_black)
        self.overlay.root.event_generate("<<StateChanged>>", when="tail")

    def _begin_wake(self):
        with self._lock:
            if self.state != State.SLEEPING:
                return
            self.state = State.WAKING
        with self._stats_lock:
            self.stats["total_off_seconds"] += time.time() - self._sleep_start
            save_stats(self.stats)
        cfg      = dict(self.cfg)
        delay_ms = int(cfg["wake_delay_s"] * 1000)
        self.overlay.root.after(0,
            lambda: self.overlay.root.after(delay_ms, lambda: self._gui_fade_in(cfg)))
        self.overlay.root.event_generate("<<StateChanged>>", when="tail")

    def _gui_fade_in(self, cfg: dict):
        with self._lock:
            self.state = State.FADING_IN
        if cfg.get("sound_enabled"):
            play_tone(cfg["sound_wake_freq"], cfg["sound_duration_ms"])

        def _done():
            with self._lock:
                self.state = State.IDLE
            self.overlay.root.event_generate("<<StateChanged>>", when="tail")

        self.overlay.fade_to(0.0, cfg.get("fade_in_ms", 1000),
                              cfg.get("fade_curve", "ease_in_out"), _done)
        self.overlay.root.event_generate("<<StateChanged>>", when="tail")

    def force_sleep(self):
        with self._lock:
            if self.state not in (State.IDLE, State.PAUSED, State.AMBIENT,
                                  State.COUNTDOWN, State.WAKING, State.FADING_IN):
                return
            was_ambient = (self.state == State.AMBIENT)
            was_waking  = self.state in (State.WAKING, State.FADING_IN)
            if was_ambient or was_waking:
                self.state = State.IDLE

        self.overlay.root.after(0, self.overlay._cancel_anim)
        self.overlay.root.after(0, self.overlay.stop_ambient)

        if not was_waking:
            self._countdown_val = 0
            self.overlay.root.after(0, self.overlay._clear_text)

        if self.cfg.get("ambient_mode") and not was_ambient and not was_waking:
            self._enter_ambient()
        else:
            self._go_to_sleep()

    def force_wake(self):
        with self._lock:
            if self.state != State.SLEEPING:
                return
        self._begin_wake()

    def update_config(self, cfg: dict):
        with self._lock:
            self.cfg = cfg


class SystemTray:
    def __init__(self, root: tk.Tk, controller: CinematicWake, cfg: dict, ui: "SettingsUI"):
        self.root       = root
        self.controller = controller
        self.cfg        = cfg
        self.ui         = ui

        self.icon = pystray.Icon(
            "CinematicWake",
            self._make_icon(),
            "CinematicWake",
            menu=self._build_menu()
        )
        threading.Thread(target=self.icon.run, daemon=True).start()

    def _make_icon(self) -> Image.Image:
        img = Image.new('RGBA', (64, 64), color=(0, 0, 0, 0))
        d   = ImageDraw.Draw(img)
        d.ellipse([4, 4, 60, 60], fill=(0, 212, 200, 255))
        d.polygon([(24, 16), (24, 48), (48, 32)], fill=(255, 255, 255, 255))
        return img

    def _build_menu(self):
        def _route(func, *args):
            return lambda _: self.root.after(0, lambda: func(*args))

        curve_items = []
        for txt, val in CURVES:
            curve_items.append(
                pystray.MenuItem(
                    txt,
                    _route(self._set_curve, val),
                    radio=True,
                    checked=lambda item, v=val: self.cfg.get("fade_curve", "ease_in_out") == v
                )
            )

        return pystray.Menu(
            pystray.MenuItem("⚡  Sleep Now", _route(self.controller.force_sleep), default=True),
            pystray.MenuItem(
                lambda item: "▶  Resume" if self.controller.state == State.PAUSED else "⏸  Pause",
                _route(self.controller._hotkey_pause),
                checked=lambda item: self.controller.state == State.PAUSED
            ),
            pystray.Menu.SEPARATOR,
            pystray.MenuItem(
                "🌙  Ambient Mode",
                _route(self._toggle_ambient),
                checked=lambda item: self.cfg.get("ambient_mode", False)
            ),
            pystray.MenuItem(
                "🔊  Sounds",
                _route(self._toggle_sound),
                checked=lambda item: self.cfg.get("sound_enabled", False)
            ),
            pystray.Menu.SEPARATOR,
            pystray.MenuItem("📈  Fade Curve", pystray.Menu(*curve_items)),
            pystray.MenuItem("⚙  Open Settings", pystray.Menu(
                pystray.MenuItem("⏱  Timing",     _route(self._show_window, 0)),
                pystray.MenuItem("🎨  Appearance", _route(self._show_window, 1)),
                pystray.MenuItem("🌙  Ambient",    _route(self._show_window, 2)),
                pystray.MenuItem("📅  Schedule",   _route(self._show_window, 3)),
                pystray.MenuItem("🔊  Sound",      _route(self._show_window, 4)),
                pystray.MenuItem("⌨  Hotkeys",    _route(self._show_window, 5)),
                pystray.MenuItem("⚙  System",     _route(self._show_window, 6)),
            )),
            pystray.Menu.SEPARATOR,
            pystray.MenuItem("✕  Quit CinematicWake", _route(self._quit))
        )

    def _toggle_ambient(self):
        new_val = not self.cfg.get("ambient_mode", False)
        self.cfg["ambient_mode"] = new_val
        save_config(self.cfg)
        self.controller.update_config(self.cfg)
        if hasattr(self.ui, "_ambient_var"):
            self.ui._ambient_var.set(new_val)
        if hasattr(self.ui, "_ambient_tog"):
            self.ui._ambient_tog.redraw()

    def _toggle_sound(self):
        new_val = not self.cfg.get("sound_enabled", False)
        self.cfg["sound_enabled"] = new_val
        save_config(self.cfg)
        self.controller.update_config(self.cfg)
        if hasattr(self.ui, "_snd_var"):
            self.ui._snd_var.set(new_val)
        if hasattr(self.ui, "_snd_tog"):
            self.ui._snd_tog.redraw()

    def _set_curve(self, val):
        self.cfg["fade_curve"] = val
        save_config(self.cfg)
        self.controller.update_config(self.cfg)
        if hasattr(self.ui, "_curve_var"):
            self.ui._curve_var.set(val)

    def _show_window(self, tab_idx: int = 0):
        self.root.deiconify()
        self.root.lift()
        self.root.focus_force()
        if hasattr(self.ui, "_notebook"):
            self.ui._notebook.select(tab_idx)

    def _quit(self):
        self.icon.stop()
        save_config(self.cfg)
        self.root.destroy()
        sys.exit(0)

    def update_tooltip(self, text: str):
        self.icon.title = text[:127]


